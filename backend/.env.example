# ---- API 鉴权 ----
# 前端请求时需携带 Authorization: Bearer <token>
API_TOKEN=enterprise-rag-dev-token

# ---- LLM 服务 (DeepSeek) ----
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
CHAT_MODEL=deepseek-v4-flash

# ---- VL 图像描述 (智谱 GLM-4.6V) ----
ZHIPU_API_KEY=your-zhipu-api-key
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# ---- 本地模型 (vLLM)，留空则使用 DashScope ----
LOCAL_MODEL_URL=
LOCAL_MODEL_NAME=

# ---- Embedding (本地 dense embedding 模型；默认使用 BAAI/bge-m3) ----
EMBEDDING_MODEL_PATH=D:\Models\BAAI\bge-m3
EMBEDDING_DIM=1024
EMBEDDING_BATCH_SIZE=4
EMBEDDING_MAX_LENGTH=8192
EMBEDDING_DEVICE=auto
EMBEDDING_USE_FP16=true

# ---- MinerU PDF 解析 ----
MINERU_BASE_URL=https://mineru.net/api/v4
MINERU_API_TOKEN=your-mineru-api-token
MINERU_MODEL_VERSION=vlm

# ---- Milvus ----
MILVUS_URI=http://localhost:19530
