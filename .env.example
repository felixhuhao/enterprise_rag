# ---- API / app ----
# Env-managed bootstrap ADMIN credential for lockout recovery (resolved to the
# pinned bootstrap admin row, bypassing the sessions table). NOT the normal
# client auth path — users sign in via the login screen with username/password.
# Use a private value for any shared deployment.
API_TOKEN=enterprise-rag-dev-token
RATE_LIMIT_PER_MINUTE=60
CORS_ORIGINS=["http://localhost:5173","http://localhost:4173"]
# Optional frontend flag. Keep false unless testing legacy structured tag governance.
VITE_ENABLE_TAG_GOVERNANCE=false

# ---- Local storage ----
GENERAL_UPLOAD_DIR=./data/general_uploads
GENERAL_PARSED_DIR=./data/general_parsed
DATABASE_PATH=./data/app.db
STORAGE_MIN_FREE_MB=1024

# ---- LLM service (DeepSeek-compatible) ----
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
CHAT_MODEL=deepseek-v4-flash
CHAT_TIMEOUT=180
INTENT_CLASSIFIER_MODEL=
INTENT_CLASSIFIER_TEMPERATURE=0.0
INTENT_CLASSIFIER_MAX_TOKENS=256
INTENT_CLASSIFIER_TIMEOUT=30

# ---- Local model endpoint (optional) ----
# Leave empty unless a local/vLLM-compatible model endpoint is used.
LOCAL_MODEL_URL=
LOCAL_MODEL_NAME=

# ---- Embedding ----
# EMBEDDING_PROVIDER: qwen (remote Qwen text-embedding-v4) or local (BGE-M3/FlagEmbedding).
# This Docker example defaults to qwen so the base image does not download torch/FlagEmbedding.
# For provider=local, include docker-compose.local-embedding.yml to mount EMBEDDING_MODEL_HOST_PATH.
EMBEDDING_PROVIDER=qwen
EMBEDDING_MODEL_HOST_PATH=/home/hao/models/BAAI/bge-m3
EMBEDDING_MODEL_NAME=text-embedding-v4
EMBEDDING_MODEL_PATH=/models/embedding
EMBEDDING_DIM=1024
EMBEDDING_BATCH_SIZE=10
EMBEDDING_MAX_LENGTH=8192
EMBEDDING_DEVICE=auto
EMBEDDING_USE_FP16=true
# Remote embedding reliability (provider=qwen only). SDK retries 408/409/429/5xx.
EMBEDDING_TIMEOUT=30
EMBEDDING_MAX_RETRIES=2

# ---- Qwen / DashScope (OpenAI-compatible; used when *_PROVIDER=qwen) ----
QWEN_API_KEY=your-qwen-api-key
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ---- MinerU PDF parsing (optional; PDF parsing is unavailable without token) ----
MINERU_BASE_URL=https://mineru.net/api/v4
MINERU_API_TOKEN=
MINERU_MODEL_VERSION=vlm
MINERU_POLL_INTERVAL=3
MINERU_POLL_TIMEOUT=1800
MINERU_UPLOAD_TIMEOUT=300
MINERU_DOWNLOAD_TIMEOUT=300

# ---- Milvus ----
# Docker Compose overrides this to http://milvus-standalone:19530.
# Local development can use http://localhost:19530.
MILVUS_URI=http://localhost:19530
MILVUS_REQUIRED_ON_STARTUP=false
MILVUS_HEALTH_TIMEOUT_SECONDS=2.0

# ---- Upload limits ----
MD_ZIP_MAX_SIZE_MB=50
UPLOAD_MAX_SIZE_MB=100

# ---- Image description ----
# IMAGE_DESCRIPTION_PROVIDER: qwen (Qwen-VL) or zhipu (GLM-4.6V).
IMAGE_DESCRIPTION_PROVIDER=qwen
ZHIPU_API_KEY=your-zhipu-api-key
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
IMAGE_DESCRIPTION_ENABLED=true
IMAGE_DESCRIPTION_MODEL=qwen3-vl-flash
IMAGE_DESCRIPTION_CONCURRENCY=3
IMAGE_DESCRIPTION_TIMEOUT=30
IMAGE_DESCRIPTION_MAX_SIZE_MB=10
